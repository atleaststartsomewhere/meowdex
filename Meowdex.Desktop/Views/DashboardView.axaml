<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sections="clr-namespace:Meowdex.Desktop.Views.Sections"
             x:Class="Meowdex.Desktop.Views.DashboardView">
  <Grid RowDefinitions="Auto,Auto,*">
    <Border Grid.Row="0"
            Background="{StaticResource SurfaceBackground}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="0,0,0,1"
            Padding="12,2"
            ZIndex="10">
      <Grid ColumnDefinitions="Auto,*" MinHeight="74">
        <StackPanel Grid.Column="0"
                    Margin="0,0,14,0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    PointerPressed="OnGoHome">
          <Image Width="24"
                 Height="24"
                 VerticalAlignment="Center"
                 Source="{SvgImage avares://Meowdex.Desktop/Assets/Icons/.App.svg}" />
          <StackPanel Spacing="1" VerticalAlignment="Center">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="The Meowdex" />
            <TextBlock Classes="muted"
                       FontSize="11"
                       Text="{Binding TotalCats, StringFormat={}{0} Feline Specimens}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Right"> 
          <ToggleButton Classes="tab-tracker nav-icon-btn"
                        IsChecked="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Adventuring, Mode=OneWay}"
                        Command="{Binding SetSectionCommand}"
                        CommandParameter="Adventuring"
                        ToolTip.Tip="Adventuring Team">
            <Image Classes="menu-icon"
                   Source="{SvgImage avares://Meowdex.Desktop/Assets/Icons/adventure-team.svg}" />
          </ToggleButton>
          <ToggleButton Classes="tab-tracker nav-icon-btn"
                        IsChecked="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Breeding, Mode=OneWay}"
                        Command="{Binding SetSectionCommand}"
                        CommandParameter="Breeding"
                        ToolTip.Tip="Breeding">
            <Image Classes="menu-icon"
                   Source="{SvgImage avares://Meowdex.Desktop/Assets/Icons/breeding.svg}" />
          </ToggleButton>
          <ToggleButton Classes="tab-tracker nav-icon-btn"
                        IsChecked="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Available, Mode=OneWay}"
                        Command="{Binding SetSectionCommand}"
                        CommandParameter="Available"
                        ToolTip.Tip="Available">
            <Image Classes="menu-icon"
                   Source="{SvgImage avares://Meowdex.Desktop/Assets/Icons/available.svg}" />
          </ToggleButton>
          <ToggleButton Classes="tab-tracker nav-icon-btn"
                        IsChecked="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=FullRoster, Mode=OneWay}"
                        Command="{Binding SetSectionCommand}"
                        CommandParameter="FullRoster"
                        ToolTip.Tip="Full Roster">
            <Image Classes="menu-icon"
                   Source="{SvgImage avares://Meowdex.Desktop/Assets/Icons/roster.svg}" />
          </ToggleButton>
          <Button Classes="primary nav-btn nav-icon-btn add-cat-btn"
                  Click="OnAddCat"
                  ToolTip.Tip="Add Cat">
            <Image Classes="menu-icon"
                   Source="{SvgImage avares://Meowdex.Desktop/Assets/Icons/add-cat.svg}" />
          </Button>
          <Button Classes="icon-btn"
                  Content="&#x2699;"
                  Click="OnSettings" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Background="{StaticResource AppBackground}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="0,0,0,1"
            Padding="12,6">
      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center">
        <ToggleButton MinWidth="84"
                      Height="28"
                      Padding="6,2"
                      Tag="1"
                      IsChecked="{Binding SelectedTeamSlotIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=0, Mode=OneWay}"
                      Click="OnTeamSlotToggle">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock FontSize="11" Classes="muted" Text="#1" />
            <TextBlock Width="54" FontSize="11" TextTrimming="CharacterEllipsis" Text="{Binding RowPriorities[0].AssignedCatName}" />
          </StackPanel>
        </ToggleButton>
        <ToggleButton MinWidth="84"
                      Height="28"
                      Padding="6,2"
                      Tag="2"
                      IsChecked="{Binding SelectedTeamSlotIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=1, Mode=OneWay}"
                      Click="OnTeamSlotToggle">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock FontSize="11" Classes="muted" Text="#2" />
            <TextBlock Width="54" FontSize="11" TextTrimming="CharacterEllipsis" Text="{Binding RowPriorities[1].AssignedCatName}" />
          </StackPanel>
        </ToggleButton>
        <ToggleButton MinWidth="84"
                      Height="28"
                      Padding="6,2"
                      Tag="3"
                      IsChecked="{Binding SelectedTeamSlotIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=2, Mode=OneWay}"
                      Click="OnTeamSlotToggle">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock FontSize="11" Classes="muted" Text="#3" />
            <TextBlock Width="54" FontSize="11" TextTrimming="CharacterEllipsis" Text="{Binding RowPriorities[2].AssignedCatName}" />
          </StackPanel>
        </ToggleButton>
        <ToggleButton MinWidth="84"
                      Height="28"
                      Padding="6,2"
                      Tag="4"
                      IsChecked="{Binding SelectedTeamSlotIndex, Converter={StaticResource EqualsConverter}, ConverterParameter=3, Mode=OneWay}"
                      Click="OnTeamSlotToggle">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock FontSize="11" Classes="muted" Text="#4" />
            <TextBlock Width="54" FontSize="11" TextTrimming="CharacterEllipsis" Text="{Binding RowPriorities[3].AssignedCatName}" />
          </StackPanel>
        </ToggleButton>

        <Button Height="28"
                Padding="8,2"
                FontSize="11"
                Content="Clear"
                Click="OnClearTeam" />
        <Button Classes="primary"
                Height="28"
                Padding="8,2"
                FontSize="11"
                Content="Retire"
                Click="OnRetireTeam" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="2">
      <StackPanel Spacing="16" Margin="24">
        <sections:SnapshotSectionView
            IsVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Snapshot}"
            IsHitTestVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Snapshot}" />
        <sections:AdventuringSectionView
            IsVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Adventuring}"
            IsHitTestVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Adventuring}" />
        <sections:BreedingSectionView
            IsVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Breeding}"
            IsHitTestVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Breeding}" />
        <sections:AvailableSectionView
            IsVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Available}"
            IsHitTestVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=Available}" />
        <sections:FullRosterSectionView
            IsVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=FullRoster}"
            IsHitTestVisible="{Binding ActiveSection, Converter={StaticResource EqualsConverter}, ConverterParameter=FullRoster}" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
